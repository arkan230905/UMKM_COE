@push('scripts')
<script>
let selectedBtklIds = [];
let btklData = [];

// Load produk data when selected
function loadProdukData() {
    const select = document.getElementById('produk_id');
    const option = select.selectedOptions[0];
    
    if (option && option.value) {
        const biayaBahan = parseFloat(option.dataset.biayaBahan) || 0;
        
        document.getElementById('displayBiayaBahan').textContent = formatRupiah(biayaBahan);
        document.getElementById('biayaBahanInput').value = biayaBahan;
        document.getElementById('summaryBiayaBahan').textContent = formatRupiah(biayaBahan);
        
        // Load BTKL data when product is selected
        loadBTKLData();
        
        updateSummary();
    } else {
        document.getElementById('displayBiayaBahan').textContent = 'Rp 0';
        document.getElementById('biayaBahanInput').value = 0;
        document.getElementById('summaryBiayaBahan').textContent = 'Rp 0';
        
        // Clear BTKL data when no product selected
        const tbody = document.getElementById('btklTableBody');
        tbody.innerHTML = '<tr><td colspan="6" class="text-center">Silakan pilih produk terlebih dahulu</td></tr>';
        
        updateSummary();
    }
}

// Load BTKL data from controller-provided data
function loadBTKLData() {
    // Use the data already loaded from controller
    const btklData = @json($prosesBtkl);
    displayBTKLTable(btklData);
}

// Display BTKL table
function displayBTKLTable(data) {
    const tbody = document.getElementById('btklTableBody');
    
    if (data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center">Tidak ada data BTKL tersedia</td></tr>';
        return;
    }
    
    tbody.innerHTML = data.map((btkl, index) => `
        <tr>
            <td class="text-center">
                <input type="checkbox" 
                       class="form-check-input btkl-checkbox" 
                       name="selected_btkl_ids[]" 
                       value="${btkl.id}"
                       data-btkl="${btkl.btkl_per_produk}"
                       data-nama="${btkl.nama_proses}"
                       onchange="updateBTKLSelection()">
            </td>
            <td>${btkl.kode_proses}</td>
            <td><strong>${btkl.nama_proses}</strong></td>
            <td>${btkl.nama_jabatan}</td>
            <td>Rp ${formatNumber(btkl.tarif_btkl)}</td>
            <td>${btkl.kapasitas_per_jam} pcs/jam</td>
            <td class="text-success fw-semibold">Rp ${formatNumber(btkl.btkl_per_produk)}</td>
        </tr>
    `).join('');
    
    // Enable submit button if data is loaded
    document.getElementById('submitBtn').disabled = data.length === 0;
}

// Update BTKL selection
function updateBTKLSelection() {
    const checkboxes = document.querySelectorAll('.btkl-checkbox:checked');
    selectedBtklIds = Array.from(checkboxes).map(cb => cb.value);
    
    // Create hidden inputs for selected BTKL IDs (array format)
    const selectedBtklIdsContainer = document.getElementById('selectedBtklIdsContainer');
    selectedBtklIdsContainer.innerHTML = '';
    
    selectedBtklIds.forEach(id => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selected_btkl_ids[]';
        input.value = id;
        selectedBtklIdsContainer.appendChild(input);
    });
    
    // Calculate total BTKL
    let totalBTKL = 0;
    checkboxes.forEach(checkbox => {
        const btklPerProduk = parseFloat(checkbox.dataset.btkl) || 0;
        totalBTKL += btklPerProduk;
    });
    
    // Update total BTKL input
    const totalBtklInput = document.getElementById('totalBtklInput');
    if (totalBtklInput) {
        totalBtklInput.value = totalBTKL;
    }
    
    // Load BOP details when BTKL is selected
    if (selectedBtklIds.length > 0) {
        loadBOPDetails(selectedBtklIds);
    } else {
        // Clear BOP details when no BTKL selected
        document.getElementById('bopSection').style.display = 'none';
        document.getElementById('bopDetailContent').innerHTML = '';
        document.getElementById('totalBopInput').value = 0;
        document.getElementById('totalBtklInput').value = 0;
        selectedBtklIdsContainer.innerHTML = '';
        updateSummary();
    }
    
    // Update summary
    updateSummary();
    
    // Enable/disable submit button
    const produkSelected = document.getElementById('produk_id').value !== '';
    const prosesSelected = selectedBtklIds.length > 0;
    document.getElementById('submitBtn').disabled = !(produkSelected && prosesSelected);
}

// Load BOP details from bop_proses table for selected BTKL IDs
function loadBOPDetails(btklIds) {
    fetch(`/master-data/api/bop-details/${btklIds.join(',')}`)
        .then(response => response.json())
        .then(data => {
            console.log('BOP data received:', data);
            
            // Calculate total BOP for summary
            const totalBOP = calculateTotalBOP(data);
            
            // Update the total BOP input for summary calculation
            const totalBopInput = document.getElementById('totalBopInput');
            if (totalBopInput) {
                totalBopInput.value = totalBOP;
            }
            
            // Update summary
            updateSummary();
            
            displayBOPDetails(data);
        })
        .catch(error => {
            console.error('Error loading BOP details:', error);
            document.getElementById('bopDetailContent').innerHTML = '<p class="text-muted">Tidak ada data BOP tersedia</p>';
        });
}

// Calculate total BOP from BOP data
function calculateTotalBOP(bopData) {
    let totalBOP = 0;
    
    bopData.forEach(bop => {
        try {
            const components = JSON.parse(bop.komponen_bop);
            
            if (Array.isArray(components)) {
                components.forEach(component => {
                    totalBOP += parseFloat(component.rate_per_hour) || 0;
                });
            } else {
                totalBOP += parseFloat(bop.total_bop_per_produk) || 0;
            }
        } catch (e) {
            totalBOP += parseFloat(bop.total_bop_per_produk) || 0;
        }
    });
    
    return totalBOP;
}

// Display BOP details
function displayBOPDetails(bopData) {
    // Show BOP section
    document.getElementById('bopSection').style.display = 'block';
    
    // Process BOP data to extract individual components from JSON
    const processedBopData = [];
    
    bopData.forEach(bop => {
        try {
            const components = JSON.parse(bop.komponen_bop);
            
            if (Array.isArray(components)) {
                components.forEach(component => {
                    processedBopData.push({
                        komponen_bop: component.component || 'Unknown',
                        total_bop_per_produk: component.rate_per_hour || 0,
                        total_bop_per_jam: component.rate_per_hour || 0
                    });
                });
            } else {
                processedBopData.push({
                    komponen_bop: bop.komponen_bop,
                    total_bop_per_produk: bop.total_bop_per_produk,
                    total_bop_per_jam: bop.total_bop_per_jam
                });
            }
        } catch (e) {
            processedBopData.push({
                komponen_bop: bop.komponen_bop,
                total_bop_per_produk: bop.total_bop_per_produk,
                total_bop_per_jam: bop.total_bop_per_jam
            });
        }
    });
    
    const content = `
        <div class="table-responsive">
            <table class="table table-sm">
                <thead class="table-light">
                    <tr>
                        <th>Nama Komponen</th>
                        <th>Total per Produk</th>
                    </tr>
                </thead>
                <tbody>
                    ${processedBopData.map(bop => `
                        <tr>
                            <td><strong>${bop.komponen_bop}</strong></td>
                            <td>Rp ${formatNumber(bop.total_bop_per_produk)}</td>
                        </tr>
                    `).join('')}
                </tbody>
            </table>
        </div>
    `;
    
    document.getElementById('bopDetailContent').innerHTML = content;
}

// Update summary
function updateSummary() {
    const biayaBahan = parseFloat(document.getElementById('biayaBahanInput').value) || 0;
    const totalBtkl = parseFloat(document.getElementById('totalBtklInput').value) || 0;
    const totalBop = parseFloat(document.getElementById('totalBopInput').value) || 0;
    
    const totalHpp = biayaBahan + totalBtkl + totalBop;
    
    document.getElementById('summaryBiayaBahan').textContent = formatRupiah(biayaBahan);
    document.getElementById('summaryBtkl').textContent = formatRupiah(totalBtkl);
    document.getElementById('summaryBop').textContent = formatRupiah(totalBop);
    document.getElementById('summaryHpp').textContent = formatRupiah(totalHpp);
}

function resetSummary() {
    document.getElementById('summaryBiayaBahan').textContent = 'Rp 0';
    document.getElementById('summaryBtkl').textContent = 'Rp 0';
    document.getElementById('summaryBop').textContent = 'Rp 0';
    document.getElementById('summaryHpp').textContent = 'Rp 0';
    document.getElementById('biayaBahanInput').value = 0;
    document.getElementById('totalBtklInput').value = 0;
    document.getElementById('totalBopInput').value = 0;
}

function formatRupiah(amount) {
    return 'Rp ' + formatNumber(amount);
}

function formatNumber(amount) {
    return new Intl.NumberFormat('id-ID').format(Math.round(amount));
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    resetSummary();
    
    // Load BTKL data on page load (data already filtered by user ID in controller)
    loadBTKLData();
    
    // Add change listeners to all checkboxes
    document.querySelectorAll('.btkl-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', updateBTKLSelection);
    });
});
</script>
@endpush
@endsection
